{
  "name": "frantics-server",
  "version": "1.0.0",
  "description": "Authoritative WebSocket game server for Frantics — the party game where the host's iPhone is the TV.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "build:embedded": "node scripts/build-embedded.mjs",
    "typecheck": "tsc --noEmit",
    "smoke": "FAST_GAME=1 tsx scripts/smoke.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "bonjour-service": "^1.4.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.28.1",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
